<section class="cs-newsletter-section">
  <div class="cs-container">
    <div class="cs-newsletter-inner cs-animate">

      {%- if section.settings.label != blank -%}
        <span class="cs-section-label">{{ section.settings.label }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <p>{{ section.settings.body }}</p>
      {%- endif -%}

      {% form 'customer', id: 'newsletter-form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">

        <div class="cs-newsletter-form">
          <label for="newsletter-email" class="visually-hidden">Email address</label>
          <input
            type="email"
            id="newsletter-email"
            name="contact[email]"
            placeholder="{{ section.settings.placeholder | default: 'your@email.com' }}"
            required
            aria-label="Email address"
            autocomplete="email"
          >
          <button type="submit" class="btn-cs-primary">
            {{ section.settings.button_text | default: 'Subscribe' }}
          </button>
        </div>

        {%- if form.posted_successfully? -%}
          <div class="cs-newsletter-success" role="alert">
            {{ section.settings.success_message | default: "✅ You're in! Check your inbox... and your alibi." }}
          </div>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="cs-newsletter-error" role="alert" style="margin-top:12px;color:#CC0000;font-size:0.875rem;">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}
      {% endform %}

      {%- if section.settings.disclaimer != blank -%}
        <p style="margin-top:12px;font-size:0.75rem;color:var(--color-foreground-muted);">
          {{ section.settings.disclaimer }}
        </p>
      {%- endif -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "CS Newsletter",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Eyebrow label",
      "default": "📬 Dispatch"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "STAY OUT OF JAIL..."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Description text",
      "default": "...but stay in the loop. Get early access to new drops, exclusive deals, and cold case discounts."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email input placeholder",
      "default": "your@email.com"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Submit button text",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "✅ You're in! Check your inbox... and your alibi."
    },
    {
      "type": "text",
      "id": "disclaimer",
      "label": "Disclaimer / fine print",
      "default": "No spam. Unsubscribe anytime. We promise not to sell your data to the feds."
    }
  ],
  "presets": [
    {
      "name": "CS Newsletter",
      "settings": {
        "label": "📬 Dispatch",
        "heading": "STAY OUT OF JAIL...",
        "body": "...but stay in the loop. Get early access to new drops, exclusive deals, and cold case discounts.",
        "placeholder": "your@email.com",
        "button_text": "Subscribe",
        "success_message": "✅ You're in! Check your inbox... and your alibi.",
        "disclaimer": "No spam. Unsubscribe anytime. We promise not to sell your data to the feds."
      }
    }
  ]
}
{% endschema %}
