<section class="cs-section-pad" id="featured">
  <div class="cs-container">

    <!-- Section Header -->
    <div class="cs-section-header cs-animate">
      {%- if section.settings.label != blank -%}
        <span class="cs-section-label">{{ section.settings.label }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2>{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subtext != blank -%}
        <p>{{ section.settings.subtext }}</p>
      {%- endif -%}
    </div>

    <!-- Product Grid -->
    {%- assign featured_collection = collections[section.settings.collection] -%}
    {%- if featured_collection != blank and featured_collection.products.size > 0 -%}
      <div class="cs-products-grid">
        {%- for product in featured_collection.products limit: section.settings.products_to_show -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      </div>
    {%- else -%}
      <!-- Fallback: show most recent products from all collections -->
      <div class="cs-products-grid">
        {%- assign fallback_products = collections.all.products -%}
        {%- for product in fallback_products limit: section.settings.products_to_show -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
        {%- if fallback_products.size == 0 -%}
          <div style="grid-column:1/-1;text-align:center;padding:3rem;color:var(--color-foreground-secondary);">
            <p>No products found. Add products to your store to see them here.</p>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- View All CTA -->
    <div class="cs-center" style="margin-top: 2.5rem;">
      {%- if featured_collection != blank -%}
        <a href="{{ featured_collection.url }}" class="btn-cs-secondary btn-lg">
          View All Products &rarr;
        </a>
      {%- else -%}
        <a href="{{ routes.all_products_collection_url }}" class="btn-cs-secondary btn-lg">
          View All Products &rarr;
        </a>
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "CS Featured Collection",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection to feature",
      "info": "Select which collection to display products from"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Number of products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Section Text"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Section eyebrow label",
      "default": "🔍 Evidence Locker"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "FEATURED SUSPECTS"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Section description",
      "default": "Our most-wanted merchandise. High quality prints on every item — because the evidence has to be rock solid."
    }
  ],
  "presets": [
    {
      "name": "CS Featured Collection",
      "settings": {
        "products_to_show": 4,
        "label": "🔍 Evidence Locker",
        "heading": "FEATURED SUSPECTS",
        "subtext": "Our most-wanted merchandise. High quality prints on every item — because the evidence has to be rock solid."
      }
    }
  ]
}
{% endschema %}
