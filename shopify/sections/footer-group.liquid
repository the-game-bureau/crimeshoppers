{% comment %}
  Horizon Section Group — Footer
  -------------------------------------------------------
  Shopify Horizon wraps the footer in a section group.
  This file defines the footer group containing the
  main footer section.

  Reference: https://shopify.dev/docs/themes/architecture/section-groups
{% endcomment %}

{% schema %}
{
  "name": "Footer group",
  "type": "footer",
  "sections": {
    "footer": {
      "type": "footer",
      "settings": {
        "brand_name": "CRIME SHOPPERS",
        "tagline": "See Something? Buy Something! Premium true crime merch for the unhealthily obsessed."
      }
    }
  },
  "order": ["footer"]
}
{% endschema %}
